.venv/
# Broadened to cover sibling sandbox / per-platform venvs in the project
# tree. The canonical sandbox venv lives at $HOME/.venv-resumasher-sandbox/
# (outside the project tree, so not matched by this).
# See CLAUDE.md "Sandbox vs host venv coordination".
.venv-*/
__pycache__/
*.pyc
.pytest_cache/
.resumasher/
applications/
examples/
.gstack/
.context/
internal_notes/
trace_comparison/
pr*_samples/
*.egg-info/
.DS_Store
