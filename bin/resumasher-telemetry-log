#!/usr/bin/env bash
# resumasher-telemetry-log — append a telemetry event to local JSONL
#
# Reads the tier from $STUDENT_CWD/.resumasher/config.json, picks up or
# generates the installation_id (community tier only), builds a JSON event
# from --flag arguments, and appends to ~/.resumasher/analytics/skill-usage.jsonl.
# Fires a backgrounded sync after logging.
#
# Usage:
#   resumasher-telemetry-log --event-type run_started --run-id <uuid> \
#     --cwd <student-cwd> [--model <model-id>] [--flag value ...]
#
# Required:
#   --event-type <type> — one of first_run_setup_completed, run_started,
#                          fit_computed, tailor_completed, placeholder_fill_choice,
#                          run_completed, run_failed, rerender_used
#   --cwd <path>        — student's working directory (source of config.json)
#
# Recommended:
#   --host <id>         — the AI CLI the orchestrator is running in. One of
#                          claude_code, codex_cli, gemini_cli. Self-reported
#                          by the orchestrator (it knows what host it is)
#                          because env-var sniffing is unreliable across
#                          host CLI versions (Codex, for instance, does not
#                          set a discoverable env var). If omitted, falls
#                          back to env-var detection, then "unknown".
#   --model <id>        — the model the AI orchestrator is running as
#                          (e.g. claude-opus-4-7, gpt-5-codex, gemini-2.5-pro).
#                          Self-reported by the LLM — the orchestrator knows
#                          what it is. Null if not passed.
#
# Env overrides (for tests):
#   RESUMASHER_STATE_DIR — override ~/.resumasher
#   RESUMASHER_DIR       — override auto-detected skill root
#
# NOTE: set -uo pipefail (no -e). Telemetry must never exit non-zero.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RESUMASHER_DIR="${RESUMASHER_DIR:-$(cd "$SCRIPT_DIR/.." && pwd)}"

# State-dir policy: SCOPE MATCHES SCOPE.
#   - User-scope install (skill at $HOME/.claude/skills/resumasher):
#     state lives in $HOME/.resumasher — one student, one installation_id
#     across all their projects.
#   - Project-scope install (skill at <project>/.claude/skills/resumasher):
#     state lives in <project>/.resumasher — deleting the project deletes
#     the telemetry state; no data leaks outside the project boundary.
#   - Override with RESUMASHER_STATE_DIR for tests.
if [ -n "${RESUMASHER_STATE_DIR:-}" ]; then
  STATE_DIR="$RESUMASHER_STATE_DIR"
else
  _GRANDPARENT="$(cd "$RESUMASHER_DIR/../.." 2>/dev/null && pwd -P || echo "")"
  if [ "$_GRANDPARENT" = "$(cd "$HOME/.claude" 2>/dev/null && pwd -P || echo "")" ]; then
    STATE_DIR="$HOME/.resumasher"
  else
    # Project-scope: project root is three directories above the skill.
    STATE_DIR="$(cd "$RESUMASHER_DIR/../../.." 2>/dev/null && pwd)/.resumasher"
  fi
fi

# Install-scope detection: "user_home" if the skill lives under any of the
# three host-CLI user-convention directories ($HOME/.claude, .codex, .gemini),
# else "project_local". Orchestrator can override via --install-scope-path.
INSTALL_SCOPE_DETECTED="project_local"
for _prefix in "$HOME/.claude/skills/" "$HOME/.codex/skills/" "$HOME/.gemini/skills/"; do
  case "$RESUMASHER_DIR/" in
    "$_prefix"*)
      INSTALL_SCOPE_DETECTED="user_home"
      break ;;
  esac
done
ANALYTICS_DIR="$STATE_DIR/analytics"
JSONL_FILE="$ANALYTICS_DIR/skill-usage.jsonl"
INSTALL_ID_FILE="$STATE_DIR/installation-id"

# ─── Parse flags ─────────────────────────────────────────────
EVENT_TYPE=""
STUDENT_CWD=""
RUN_ID=""
SESSION_ID=""
DURATION=""
OUTCOME=""
ERROR_CLASS=""
FAILED_PHASE=""

# Tailor / application
COMPANY=""
JOB_TITLE=""
SENIORITY=""
FIT_SCORE=""
FIT_STRENGTHS_COUNT=""
FIT_GAPS_COUNT=""
FIT_RECOMMENDATION=""
NUM_PLACEHOLDERS=""
USED_MULTIROLE=""

# Configuration
STYLE=""
PHOTO_INCLUDED=""
GITHUB_CONFIGURED=""
USED_GITHUB=""
USED_FOLDER=""
GITHUB_REPOS_COUNT=""
FOLDER_FILES_COUNT=""
JD_SOURCE_MODE=""
RESUME_FORMAT=""
INSTALL_SCOPE=""
ALL_PDFS_RENDERED=""

# Phase 7 / re-render / setup
CHOICE_TYPE=""
RERENDER_KIND=""
SETUP_DURATION=""
SETUP_OUTCOME=""

# Ambient
TIME_OF_DAY=""
MODEL=""
HOST_OVERRIDE=""

while [ $# -gt 0 ]; do
  case "$1" in
    --event-type)             EVENT_TYPE="$2"; shift 2 ;;
    --cwd)                    STUDENT_CWD="$2"; shift 2 ;;
    --run-id)                 RUN_ID="$2"; shift 2 ;;
    --session-id)             SESSION_ID="$2"; shift 2 ;;
    --duration)               DURATION="$2"; shift 2 ;;
    --outcome)                OUTCOME="$2"; shift 2 ;;
    --error-class)            ERROR_CLASS="$2"; shift 2 ;;
    --failed-phase)           FAILED_PHASE="$2"; shift 2 ;;
    --company)                COMPANY="$2"; shift 2 ;;
    --job-title)              JOB_TITLE="$2"; shift 2 ;;
    --seniority)              SENIORITY="$2"; shift 2 ;;
    --fit-score)              FIT_SCORE="$2"; shift 2 ;;
    --fit-strengths-count)    FIT_STRENGTHS_COUNT="$2"; shift 2 ;;
    --fit-gaps-count)         FIT_GAPS_COUNT="$2"; shift 2 ;;
    --fit-recommendation)     FIT_RECOMMENDATION="$2"; shift 2 ;;
    --num-placeholders)       NUM_PLACEHOLDERS="$2"; shift 2 ;;
    --used-multirole-format)  USED_MULTIROLE="$2"; shift 2 ;;
    --style)                  STYLE="$2"; shift 2 ;;
    --photo-included)         PHOTO_INCLUDED="$2"; shift 2 ;;
    --github-configured)      GITHUB_CONFIGURED="$2"; shift 2 ;;
    --used-github-evidence)   USED_GITHUB="$2"; shift 2 ;;
    --used-folder-evidence)   USED_FOLDER="$2"; shift 2 ;;
    --github-repos-count)     GITHUB_REPOS_COUNT="$2"; shift 2 ;;
    --folder-files-count)     FOLDER_FILES_COUNT="$2"; shift 2 ;;
    --jd-source-mode)         JD_SOURCE_MODE="$2"; shift 2 ;;
    --resume-format)          RESUME_FORMAT="$2"; shift 2 ;;
    --install-scope-path)     INSTALL_SCOPE="$2"; shift 2 ;;
    --all-pdfs-rendered)      ALL_PDFS_RENDERED="$2"; shift 2 ;;
    --choice-type)            CHOICE_TYPE="$2"; shift 2 ;;
    --rerender-kind)          RERENDER_KIND="$2"; shift 2 ;;
    --setup-duration)         SETUP_DURATION="$2"; shift 2 ;;
    --setup-outcome)          SETUP_OUTCOME="$2"; shift 2 ;;
    --time-of-day)            TIME_OF_DAY="$2"; shift 2 ;;
    --model)                  MODEL="$2"; shift 2 ;;
    --host)                   HOST_OVERRIDE="$2"; shift 2 ;;
    *) shift ;;
  esac
done

# ─── Required ───────────────────────────────────────────────
[ -z "$EVENT_TYPE" ] && exit 0
[ -z "$STUDENT_CWD" ] && exit 0

# ─── Idempotency guard for bookend events ──────────────────
# run_started / run_completed / run_failed should fire exactly once per run_id.
# If the orchestrator retries a phase (e.g., after a transient error), it can
# accidentally re-enter Phase 1 or Phase 9 and fire these a second time for
# the same run_id. Detect via marker file and skip the dup silently.
#
# placeholder_fill_choice is intentionally exempt (fires N times per run).
# fit_computed / tailor_completed are not deduped either — a legitimate
# retry of those phases produces a new fit/tailor result worth recording.
# rerender_used has no run_id and fires per user action.
case "$EVENT_TYPE" in
  run_started|run_completed|run_failed)
    if [ -n "$RUN_ID" ]; then
      # STATE_DIR isn't known here yet (the block that sets it runs later).
      # Compute the scope-aware path inline.
      _SCOPE_GRANDPARENT="$(cd "$RESUMASHER_DIR/../.." 2>/dev/null && pwd -P || echo "")"
      if [ -n "${RESUMASHER_STATE_DIR:-}" ]; then
        _SD="$RESUMASHER_STATE_DIR"
      elif [ "$_SCOPE_GRANDPARENT" = "$(cd "$HOME/.claude" 2>/dev/null && pwd -P || echo "")" ]; then
        _SD="$HOME/.resumasher"
      else
        _SD="$(cd "$RESUMASHER_DIR/../../.." 2>/dev/null && pwd)/.resumasher"
      fi
      _FIRED_DIR="$_SD/run/fired"
      _FIRED_MARKER="$_FIRED_DIR/${RUN_ID}-${EVENT_TYPE}"
      if [ -f "$_FIRED_MARKER" ]; then
        exit 0
      fi
      mkdir -p "$_FIRED_DIR" 2>/dev/null
      touch "$_FIRED_MARKER" 2>/dev/null || true
    fi
    ;;
esac

# ─── Read tier ──────────────────────────────────────────────
CONFIG="$STUDENT_CWD/.resumasher/config.json"
TIER="off"
if [ -f "$CONFIG" ]; then
  # Extract "telemetry" field via grep/awk to avoid a jq dependency.
  TIER_RAW="$(grep -o '"telemetry"[[:space:]]*:[[:space:]]*"[^"]*"' "$CONFIG" 2>/dev/null \
    | head -1 | awk -F'"' '{print $4}')"
  case "$TIER_RAW" in
    off|anonymous|community) TIER="$TIER_RAW" ;;
    *) TIER="off" ;;
  esac
fi

# If tier is off, do nothing.
[ "$TIER" = "off" ] && exit 0

# ─── Compute time_of_day_bucket if not passed ────────────────
# LOCAL timezone via `date +%H` — NOT UTC.
if [ -z "$TIME_OF_DAY" ]; then
  HOUR="$(date +%H 2>/dev/null || echo "")"
  case "$HOUR" in
    0[0-5]) TIME_OF_DAY="late_night" ;;
    0[6-9]|1[0-1]) TIME_OF_DAY="morning" ;;
    1[2-7]) TIME_OF_DAY="afternoon" ;;
    1[8-9]|2[0-3]) TIME_OF_DAY="evening" ;;
    *) TIME_OF_DAY="unknown" ;;
  esac
fi

# ─── Environment ────────────────────────────────────────────
TS="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "")"
RESUMASHER_VERSION="$(cat "$RESUMASHER_DIR/VERSION" 2>/dev/null | tr -d '[:space:]' || echo "unknown")"
# Fallback: derive from CHANGELOG if no VERSION file
if [ "$RESUMASHER_VERSION" = "unknown" ] && [ -f "$RESUMASHER_DIR/CHANGELOG.md" ]; then
  RESUMASHER_VERSION="$(grep -oE '^## \[?v?[0-9]+\.[0-9]+\.[0-9]+' "$RESUMASHER_DIR/CHANGELOG.md" 2>/dev/null \
    | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' || echo "unknown")"
fi
OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
ARCH="$(uname -m)"

# Host: prefer the orchestrator's self-reported value (passed via --host),
# then RESUMASHER_HOST env override (used by tests), then env-var sniffing,
# then "unknown". Self-reporting is more reliable than sniffing because host
# CLIs don't consistently set discoverable env vars (Codex in particular).
HOST="$HOST_OVERRIDE"
if [ -z "$HOST" ]; then
  HOST="${RESUMASHER_HOST:-}"
fi
if [ -z "$HOST" ]; then
  if [ -n "${CLAUDE_CODE_VERSION:-}${CLAUDECODE:-}" ]; then
    HOST="claude_code"
  elif [ -n "${CODEX_VERSION:-}${CODEX:-}" ]; then
    HOST="codex_cli"
  elif [ -n "${GEMINI_VERSION:-}${GEMINI_CLI:-}" ]; then
    HOST="gemini_cli"
  else
    HOST="unknown"
  fi
fi

# ─── Installation ID (community tier only) ───────────────────
INSTALL_ID=""
if [ "$TIER" = "community" ]; then
  if [ -f "$INSTALL_ID_FILE" ]; then
    INSTALL_ID="$(cat "$INSTALL_ID_FILE" 2>/dev/null | tr -d '[:space:]')"
  fi
  if [ -z "$INSTALL_ID" ]; then
    if command -v uuidgen >/dev/null 2>&1; then
      INSTALL_ID="$(uuidgen | tr '[:upper:]' '[:lower:]')"
    elif [ -r /proc/sys/kernel/random/uuid ]; then
      INSTALL_ID="$(cat /proc/sys/kernel/random/uuid)"
    else
      INSTALL_ID="$(od -An -tx1 -N16 /dev/urandom 2>/dev/null | tr -d ' \n')"
    fi
    if [ -n "$INSTALL_ID" ]; then
      mkdir -p "$STATE_DIR" 2>/dev/null
      printf '%s' "$INSTALL_ID" > "$INSTALL_ID_FILE" 2>/dev/null
    fi
  fi
fi

# ─── JSON helpers ────────────────────────────────────────────
# Sanitize string for JSON: strip quotes, backslashes, control chars; cap length.
json_str() {
  local raw="$1" maxlen="${2:-200}"
  printf '%s' "$raw" | tr -d '"\\' | tr '\n\r\t' '   ' | head -c "$maxlen"
}

# Emit a JSON field (key:value) or empty string if value is blank.
# kind=s for string (quotes+escape), n for number, b for boolean.
# Numeric values get defensive whitespace/newline stripping — catches the
# classic "grep -c ... || echo 0" caller bug that produces "0\n0" and
# would otherwise embed a literal newline into the JSONL.
f_str() { [ -n "$2" ] && printf ',"%s":"%s"' "$1" "$(json_str "$2")"; }
f_num() {
  local v
  # Take the FIRST whitespace-delimited token. Handles the classic caller
  # bug where `grep -c X || echo 0` emits "0\n0" on zero matches (grep -c
  # prints "0" even on exit 1, then || echo appends another). Blindly
  # stripping whitespace would turn "0\n0" into "00" which fails JSON
  # strict number parsing. Taking only the first token gives "0", correct.
  v="$(printf '%s' "$2" | awk 'NF {print $1; exit}' 2>/dev/null | head -c 32)"
  [ -n "$v" ] && printf ',"%s":%s' "$1" "$v"
}
f_bool() {
  local v
  v="$(printf '%s' "$2" | tr -d ' \n\r\t')"
  case "$v" in
    true|TRUE|True|1)  printf ',"%s":true'  "$1" ;;
    false|FALSE|False|0) printf ',"%s":false' "$1" ;;
  esac
}

# ─── Build event JSON ────────────────────────────────────────
mkdir -p "$ANALYTICS_DIR" 2>/dev/null

# Core fields (always present).
LINE='{"v":1'
LINE+=',"event_type":"'"$(json_str "$EVENT_TYPE" 50)"'"'
LINE+=',"ts":"'"$TS"'"'
LINE+=',"resumasher_version":"'"$(json_str "$RESUMASHER_VERSION" 20)"'"'
LINE+=',"host":"'"$(json_str "$HOST" 20)"'"'
LINE+=',"os":"'"$(json_str "$OS" 20)"'"'
LINE+=',"arch":"'"$(json_str "$ARCH" 20)"'"'
LINE+=',"time_of_day_bucket":"'"$(json_str "$TIME_OF_DAY" 20)"'"'

# Optional model identifier (self-reported by the AI orchestrator).
LINE+="$(f_str model "$MODEL")"

# Optional correlation
LINE+="$(f_str run_id "$RUN_ID")"
LINE+="$(f_str session_id "$SESSION_ID")"

# Installation ID (only under community tier; JSONL itself omits it otherwise,
# so a later tier downgrade doesn't leak past events' IDs).
[ -n "$INSTALL_ID" ] && LINE+=',"installation_id":"'"$INSTALL_ID"'"'

# Event-specific
LINE+="$(f_num duration_s "$DURATION")"
LINE+="$(f_str outcome "$OUTCOME")"
LINE+="$(f_str error_class "$ERROR_CLASS")"
LINE+="$(f_num failed_phase "$FAILED_PHASE")"

# Tailor/application
LINE+="$(f_str company "$COMPANY")"
LINE+="$(f_str job_title "$JOB_TITLE")"
LINE+="$(f_str seniority "$SENIORITY")"
LINE+="$(f_num fit_score "$FIT_SCORE")"
LINE+="$(f_num fit_strengths_count "$FIT_STRENGTHS_COUNT")"
LINE+="$(f_num fit_gaps_count "$FIT_GAPS_COUNT")"
LINE+="$(f_str fit_recommendation "$FIT_RECOMMENDATION")"
LINE+="$(f_num num_placeholders_emitted "$NUM_PLACEHOLDERS")"
LINE+="$(f_bool used_multirole_format "$USED_MULTIROLE")"

# Configuration
LINE+="$(f_str style_chosen "$STYLE")"
LINE+="$(f_bool photo_included "$PHOTO_INCLUDED")"
LINE+="$(f_bool github_configured "$GITHUB_CONFIGURED")"
LINE+="$(f_bool used_github_evidence "$USED_GITHUB")"
LINE+="$(f_bool used_folder_evidence "$USED_FOLDER")"
LINE+="$(f_num github_repos_count "$GITHUB_REPOS_COUNT")"
LINE+="$(f_num folder_files_count "$FOLDER_FILES_COUNT")"
LINE+="$(f_str jd_source_mode "$JD_SOURCE_MODE")"
LINE+="$(f_str resume_format_detected "$RESUME_FORMAT")"
# Use --install-scope-path override if provided, else the auto-detected value.
LINE+="$(f_str install_scope_path "${INSTALL_SCOPE:-$INSTALL_SCOPE_DETECTED}")"
LINE+="$(f_bool all_pdfs_rendered "$ALL_PDFS_RENDERED")"

# Phase 7 / re-render / setup
LINE+="$(f_str choice_type "$CHOICE_TYPE")"
LINE+="$(f_str rerender_kind "$RERENDER_KIND")"
LINE+="$(f_num setup_duration_s "$SETUP_DURATION")"
LINE+="$(f_str setup_outcome "$SETUP_OUTCOME")"

LINE+='}'

echo "$LINE" >> "$JSONL_FILE" 2>/dev/null || true

# ─── Sync only on terminal events ────────────────────────────
# Measurement: syncing after EVERY event = ~515ms × 9 = ~4.6s per run
# (9 separate HTTP round-trips, each with JWT validation + edge function
# invocation). Syncing only at "terminal" events batches the queued events
# into one POST: one round-trip covers everything, ~500-700ms total per run.
#
# Terminal events that trigger a flush:
#   - first_run_setup_completed: end of Phase 0 setup (standalone event)
#   - run_completed:             end of a successful pipeline run
#   - run_failed:                end of a failed pipeline run
#   - rerender_used:             end of a standalone rerender action
#
# Mid-run events (run_started, fit_computed, tailor_completed,
# placeholder_fill_choice) only write to JSONL; the terminal event that
# closes the run flushes them. If the student kills the process before a
# terminal event fires, those mid-run events sit in JSONL and ship on
# the next run (cursor-based sync catches them up). Best of our abilities.
case "$EVENT_TYPE" in
  first_run_setup_completed|run_completed|run_failed|rerender_used)
    SYNC="$RESUMASHER_DIR/bin/resumasher-telemetry-sync"
    if [ -x "$SYNC" ]; then
      "$SYNC" 2>/dev/null || true
    fi
    ;;
esac

exit 0
